generator client {
  provider = "prisma-client-js"
  output   = "../apps/files/src/generated/prisma/files-client"

}

datasource db {
  provider = "postgresql"
}

enum Purpose {
  POST_IMAGE
  BILL
}

enum Mime {
  JPEG
  PNG
}

enum FileStatus {
  PENDING
  UPLOADED
  READY
  FAILED
  DELETED
}

model File {
  id           String      @id @default(uuid()) @db.Uuid
  ownerId      String      @db.Uuid
  originalName String
  purpose      Purpose
  mimeType     Mime
  size         Int
  storageKey   String       @unique
  bucket       String
  status       FileStatus  @default(PENDING)
  checksum     String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  uploadedAt   DateTime?
  readyAt      DateTime?
  failedAt     DateTime?
  deletedAt    DateTime?
  failedReason String?

  @@index([ownerId])
  @@index([status])
  @@index([ownerId, status])

  @@map("file")
}