generator client {
  provider = "prisma-client-js"
  output   = "../apps/files/src/generated/prisma/files-client"

}

datasource db {
  provider = "postgresql"
}

model FileAsset {
  id         String   @id @default(uuid()) @db.Uuid
  ownerId    String   @db.Uuid
  purpose    String
  bucket     String
  objectKey  String   @unique
  mimeType   String
  size       Int
  checksum   String?
  status     String
  url        String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([ownerId])
}