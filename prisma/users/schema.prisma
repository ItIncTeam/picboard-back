generator client {
  provider = "prisma-client-js"
  output   = "../apps/users/src/generated/prisma/users-client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String   @id @default(uuid()) @db.Uuid
  email                String   @unique
  username             String   @unique
  passwordHash         String
  displayName          String?
  bio                  String?
  profilePictureFileId String?  @db.Uuid
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
