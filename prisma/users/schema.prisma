generator client {
  provider = "prisma-client-js"
  output   = "../apps/users/src/generated/prisma/users-client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String         @id @default(uuid()) @db.Uuid
  email                   String         @unique
  username                String         @unique
  passwordHash            String?
  confirmationCode        String?
  confirmationCodeExpDate DateTime?      @db.Timestamptz(6)
  isConfirmed             Boolean        @default(false)
  displayName             String?
  bio                     String?
  profilePictureFileId    String?        @db.Uuid
  createdAt               DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt               DateTime       @updatedAt @db.Timestamptz(6)
  oauthAccount            OAuthAccount[]
}

model OAuthAccount {
  id         String  @id @default(uuid()) @db.Uuid
  userId     String  @db.Uuid
  provider   String // 'google' or 'github'
  providerId String
  username   String?
  email      String?
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
   @@index([userId]) // relation scalar fields used in joins/lookups should be indexed for performance as data grows
}
