{
  "name": "picboard-back",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:users": "nest build users-microservice",
    "build:posts": "nest build posts-microservice",
    "build:files": "nest build files-microservice",
    "build:gateway": "nest build gateway-microservice",
    "start:dev:all": "cross-env NODE_ENV=development nest start users-microservice --watch && cross-env NODE_ENV=development nest start posts-microservice --watch && cross-env NODE_ENV=development nest start files-microservice --watch && cross-env NODE_ENV=development nest start gateway --watch",
    "start:dev:users": "cross-env NODE_ENV=development nest start users-microservice --watch",
    "start:dev:posts": "cross-env NODE_ENV=development nest start posts-microservice --watch",
    "start:dev:files": "cross-env NODE_ENV=development.local nest start files-microservice --watch",
    "start:dev:gateway": "cross-env NODE_ENV=development nest start gateway --watch",
    "start:staging:users": "cross-env NODE_ENV=staging nest start users-microservice",
    "start:staging:posts": "cross-env NODE_ENV=staging nest start posts-microservice",
    "start:staging:files": "cross-env NODE_ENV=staging nest start files-microservice",
    "start:staging:gateway": "cross-env NODE_ENV=staging nest start gateway",
    "start:prod:users": "cross-env NODE_ENV=production node dist/apps/users-microservice/main",
    "start:prod:posts": "cross-env NODE_ENV=production node dist/apps/posts-microservice/main",
    "start:prod:files": "cross-env NODE_ENV=production node dist/apps/files-microservice/main",
    "start:prod:gateway": "cross-env NODE_ENV=production node dist/apps/gateway/main",
    "test:users:e2e": "cross-env NODE_ENV=testing dotenv -e apps/users-microservice/src/env/.env.testing -- jest --config ./apps/users-microservice/test/jest-e2e.json",
    "test:posts:e2e": "cross-env NODE_ENV=testing jest --config ./apps/posts-microservice/test/jest-e2e.json",
    "test:files:e2e": "cross-env NODE_ENV=testing jest --config ./apps/files-microservice/test/jest-e2e.json",
    "test:gateway:e2e": "cross-env NODE_ENV=testing jest --config ./apps/gateway/test/jest-e2e.json",
    "prisma:generate:users": "dotenv -e apps/users-microservice/src/env/.env.development.local -- prisma generate --config prisma/users/prisma.config.ts",
    "prisma:generate:posts": "dotenv -e apps/posts-microservice/src/env/.env.development.local -- prisma generate --config prisma/posts/prisma.config.ts",
    "prisma:generate:files": "dotenv -e apps/files-microservice/src/env/.env.development.local -- prisma generate --config prisma/files/prisma.config.ts",
    "prisma:migrate:dev:users": "dotenv -e apps/users-microservice/src/env/.env.development.local -- prisma migrate dev --config prisma/users/prisma.config.ts",
    "prisma:migrate:dev:posts": "dotenv -e apps/posts-microservice/src/env/.env.development.local -- prisma migrate dev --config prisma/posts/prisma.config.ts",
    "prisma:migrate:dev:files": "dotenv -e apps/files-microservice/src/env/.env.development.local -- prisma migrate dev --config prisma/files/prisma.config.ts",
    "prisma:migrate:staging:users": "dotenv -e apps/users-microservice/src/env/.env.staging -- prisma migrate deploy --config prisma/users/prisma.config.ts",
    "prisma:migrate:staging:posts": "dotenv -e apps/posts-microservice/src/env/.env.staging -- prisma migrate deploy --config prisma/posts/prisma.config.ts",
    "prisma:migrate:staging:files": "dotenv -e apps/files-microservice/src/env/.env.staging -- prisma migrate deploy --config prisma/files/prisma.config.ts",
    "prisma:migrate:prod:users": "dotenv -e apps/users-microservice/src/env/.env.production -- prisma migrate deploy --config prisma/users/prisma.config.ts",
    "prisma:migrate:prod:posts": "dotenv -e apps/posts-microservice/src/env/.env.production -- prisma migrate deploy --config prisma/posts/prisma.config.ts",
    "prisma:migrate:prod:files": "dotenv -e apps/files-microservice/src/env/.env.production -- prisma migrate deploy --config prisma/files/prisma.config.ts",
    "prisma:migrate:test:users": "dotenv -e apps/users-microservice/src/env/.env.testing -- prisma migrate deploy --config prisma/users/prisma.config.ts",
    "prisma:migrate:test:posts": "dotenv -e apps/posts-microservice/src/env/.env.testing -- prisma migrate deploy --config prisma/posts/prisma.config.ts",
    "prisma:migrate:test:files": "dotenv -e apps/files-microservice/src/env/.env.testing -- prisma migrate deploy --config prisma/files/prisma.config.ts",
    "prisma:migration:status:users": "dotenv -e apps/users-microservice/src/env/.env.development -- prisma migrate status --config prisma/users/prisma.config.ts",
    "prisma:migration:status:posts": "dotenv -e apps/posts-microservice/src/env/.env.development -- prisma migrate status --config prisma/posts/prisma.config.ts",
    "prisma:migration:status:files": "dotenv -e apps/files-microservice/src/env/.env.development -- prisma migrate status --config prisma/files/prisma.config.ts",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start:dev": "nest start --watch",
    "prisma:generate:users:prod": "dotenv -e apps/users-microservice/src/env/.env.production -- prisma generate --config prisma/users/prisma.config.ts",
    "prisma:generate:users:jenkins": "prisma generate --config prisma/users/prisma.config.ts",
    "start:debug": "nest start --debug --watch",
    "start:prod": "cross-env NODE_ENV=production node dist/apps/picboard-back/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand"
  },
  "dependencies": {
    "@apollo/gateway": "^2.14.0",
    "@apollo/server": "^5.5.1",
    "@apollo/subgraph": "^2.14.0",
    "@as-integrations/express5": "^1.1.2",
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/s3-request-presigner": "^3.1073.0",
    "@nestjs/apollo": "^13.1.4",
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/graphql": "^13.1.4",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.9",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.9",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "@types/supertest": "^7.2.0",
    "amqp-connection-manager": "^4.1.14",
    "amqplib": "^0.10.5",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "graphql": "^16.11.0",
    "node-fetch": "^3.3.2",
    "nodemailer": "^7.0.7",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.7",
    "@nestjs/testing": "^11.1.9",
    "@types/amqplib": "^0.10.8",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^11.0.0",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@app/auth(|/.*)$": "<rootDir>/libs/auth/src/$1",
      "^@app/common(|/.*)$": "<rootDir>/libs/common/src/$1",
      "^@app/contracts(|/.*)$": "<rootDir>/libs/contracts/src/$1",
      "^@app/rmq(|/.*)$": "<rootDir>/libs/rmq/src/$1",
      "^uuid$": "<rootDir>/__mocks__/uuid.js"
    }
  }
}
