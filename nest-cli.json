{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/gateway/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/gateway/tsconfig.app.json",
    "assets": [{ "include": "**/env/*", "watchAssets": true }]
  },
  "monorepo": true,
  "root": "apps/gateway",
  "projects": {
    "auth": {
      "type": "library",
      "root": "libs/auth",
      "entryFile": "index",
      "sourceRoot": "libs/auth/src",
      "compilerOptions": {
        "tsConfigPath": "libs/auth/tsconfig.lib.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "contracts": {
      "type": "library",
      "root": "libs/contracts",
      "entryFile": "index",
      "sourceRoot": "libs/contracts/src",
      "compilerOptions": {
        "tsConfigPath": "libs/contracts/tsconfig.lib.json"
      }
    },
    "files-microservice": {
      "type": "application",
      "root": "apps/files-microservice",
      "entryFile": "main",
      "sourceRoot": "apps/files-microservice/src",
      "compilerOptions": {
        "tsConfigPath": "apps/files-microservice/tsconfig.app.json"
      }
    },
    "gateway": {
      "type": "application",
      "root": "apps/gateway",
      "entryFile": "main",
      "sourceRoot": "apps/gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/gateway/tsconfig.app.json"
      }
    },
    "posts-microservice": {
      "type": "application",
      "root": "apps/posts-microservice",
      "entryFile": "main",
      "sourceRoot": "apps/posts-microservice/src",
      "compilerOptions": {
        "tsConfigPath": "apps/posts-microservice/tsconfig.app.json"
      }
    },
    "rmq": {
      "type": "library",
      "root": "libs/rmq",
      "entryFile": "index",
      "sourceRoot": "libs/rmq/src",
      "compilerOptions": {
        "tsConfigPath": "libs/rmq/tsconfig.lib.json"
      }
    },
    "users-microservice": {
      "type": "application",
      "root": "apps/users-microservice",
      "entryFile": "main",
      "sourceRoot": "apps/users-microservice/src",
      "compilerOptions": {
        "tsConfigPath": "apps/users-microservice/tsconfig.app.json"
      }
    }
  }
}
